name: Deploy to Pages

on:
  push:
    branches: ["main"]

permissions:
  pages: write  # Global if needed
  id-token: write

jobs:
  deploy:
    runs-on: ubuntu-latest
    permissions:  # Or here if per-job
      pages: write
      id-token: write
      contents: read
    steps:
    - uses: actions/checkout@v4
    - uses: actions/configure-pages@v5
    - uses: actions/upload-pages-artifact@v3
      with:
        path: '.'
    - uses: actions/deploy-pages@v4
